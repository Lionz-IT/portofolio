---
import BaseLayout from '../layouts/BaseLayout.astro';
import Cursor from '../components/Cursor.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import About from '../components/About.astro';
import Works from '../components/Works.astro';
import Stack from '../components/Stack.astro';
import Experience from '../components/Experience.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import FloatingSocials from '../components/FloatingSocials.astro';
import Preloader from '../components/Preloader.astro';
---

<BaseLayout>
  <Preloader />
  <Cursor />
  
  <div id="navbar-container" style="opacity: 0; visibility: hidden;">
    <Navbar />
    <FloatingSocials />
  </div>

  <main>
    <Hero />
    
    <!-- Menerapkan margin-top: -100vh agar section ini tumpang tindih dengan akhir dari pin spacer Hero -->
    <div id="next-section" style="margin-top: -100vh; position: relative; z-index: 10; background-color: var(--color-bg);">
      <Marquee />
      <About />
      <Works />
      <Stack />
      <Experience />
      <Contact />
      <Footer />
    </div>
  </main>
</BaseLayout>

<script>
  import '../scripts/lenis';
  import '../scripts/cursor';
  import '../scripts/hero-video';
  import '../scripts/animations';
</script>
