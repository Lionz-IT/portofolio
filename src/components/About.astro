---
import SectionLayout from '../layouts/SectionLayout.astro';
---

<SectionLayout id="about" className="about" label="01 / About" title="About Me">
  <div class="about__grid">
    <div class="about__text">
      <p class="about__bio" data-animate="fade-up">
        I am a <strong>Software Engineer</strong> specializing in <strong>Full Stack</strong> & <strong>Mobile Development</strong> based in Surabaya, Indonesia.
        I am highly dedicated to continuous growth and crafting interactive digital works
        that are functional, structured, and enjoyable to use.
      </p>
      <p class="about__bio" data-animate="fade-up">
        For me, every line of code is an opportunity to learn and improve. I always
        strive to push my boundaries, whether in developing full-scale web applications or creating 
        interactive game experiences.
      </p>
    </div>
    <div class="about__details" data-animate="fade-up">
      <dl class="about__dl">
        <div class="about__dl-row">
          <dt>Location</dt>
          <dd>Surabaya, Indonesia</dd>
        </div>
        <div class="about__dl-row">
          <dt>Focus</dt>
          <dd>Full Stack & Mobile Dev</dd>
        </div>
        <div class="about__dl-row">
          <dt>Email</dt>
          <dd>raymlg2005@gmail.com</dd>
        </div>
        <div class="about__dl-row">
          <dt>Languages</dt>
          <dd>Bahasa Indonesia, English</dd>
        </div>
      </dl>
    </div>
  </div>
</SectionLayout>

<style>
  .about__grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-lg);
    align-items: start;
  }

  .about__bio {
    font-size: var(--text-body);
    line-height: 1.8;
    color: var(--color-text-secondary);
    max-width: 540px;
  }

  .about__bio + .about__bio {
    margin-top: var(--space-sm);
  }

  .about__dl {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .about__dl-row {
    display: flex;
    justify-content: space-between;
    padding-bottom: var(--space-xs);
    border-bottom: 1px solid var(--color-border);
  }

  .about__dl-row dt {
    font-family: var(--font-mono);
    font-size: var(--text-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
  }

  .about__dl-row dd {
    font-size: var(--text-small);
    color: var(--color-text);
    text-align: right;
  }

  @media (max-width: 1024px) {
    .about__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-md);
    }
  }

  @media (max-width: 768px) {
    .about__grid {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .about__bio {
      max-width: 100%;
    }

    .about__dl-row {
      flex-direction: column;
      gap: var(--space-xs);
      align-items: flex-start;
    }

    .about__dl-row dd {
      text-align: left;
    }
  }
</style>
