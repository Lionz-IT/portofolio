<section class="hero" id="hero">
  <div class="hero__content">
    <canvas id="hero-sequence-canvas" class="hero__fullscreen-canvas"></canvas>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100vh;
    width: 100vw;
    overflow: hidden;
    background-color: var(--color-bg, #0A0A0A);
  }

  .hero__content {
    position: relative;
    width: 100%;
    height: 100%;
    z-index: 1;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__fullscreen-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
