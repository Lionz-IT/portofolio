<section class="hero" id="hero">
  <div class="hero__content">
    <canvas id="hero-sequence-canvas" class="hero__fullscreen-canvas"></canvas>
    
    <div id="scroll-indicator" class="hero__scroll-indicator">
      <span class="hero__scroll-text">Scroll</span>
      <div class="hero__scroll-line">
        <div class="hero__scroll-line-inner"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100vh;
    width: 100vw;
    overflow: hidden;
    background-color: var(--color-bg, #0A0A0A);
  }

  .hero__content {
    position: relative;
    width: 100%;
    height: 100%;
    z-index: 1;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__fullscreen-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* --- Scroll Indicator Redesign --- */
  .hero__scroll-indicator {
    position: absolute;
    bottom: clamp(1.5rem, 4vw, 3rem);
    right: clamp(1.5rem, 4vw, 3rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    z-index: 20; /* Ensure it's above the video */
    
    /* Solid White Background */
    background-color: #FFFFFF;
    padding: 1.5rem 1rem;
    border-radius: 50px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    
    transition: opacity 0.5s ease;
  }

  .hero__scroll-text {
    font-family: var(--font-mono);
    font-size: 1rem; /* Bigger */
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    writing-mode: vertical-rl;
    color: #000000; /* Black text */
  }

  .hero__scroll-line {
    width: 2px; /* Thicker */
    height: 60px; /* Longer */
    background-color: rgba(0, 0, 0, 0.15); /* Light gray/black background for the track */
    position: relative;
    overflow: hidden;
    border-radius: 2px;
  }

  .hero__scroll-line-inner {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #000000; /* Solid black line animating */
    animation: scrollLine 2s cubic-bezier(0.645, 0.045, 0.355, 1) infinite;
  }

  @keyframes scrollLine {
    0% { transform: translateY(-100%); }
    50% { transform: translateY(0); }
    100% { transform: translateY(100%); }
  }
</style>
