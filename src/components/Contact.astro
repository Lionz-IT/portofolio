---
import SectionLayout from '../layouts/SectionLayout.astro';

const socialLinks = [
  { label: 'Resume', href: '/resume.pdf' },
  { label: 'GitHub', href: 'https://github.com/Lionz-IT' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/rafif-ahmad-yudhistira-04836331b/' },
  { label: 'Instagram', href: 'https://instagram.com/ray.lionz' },
  { label: 'Roblox', href: 'https://www.roblox.com/users/profile?username=LionNichBoss' },
];
---

<SectionLayout id="contact" className="contact" label="05 / Contact" title="Let's Work Together">
  <div class="contact__body" data-animate="fade-up">
    <p class="contact__text">
      Have a project in mind or just want to say hello? I'm always open to
      discussing new opportunities and ideas.
    </p>
    
    <a href="#" class="contact__email" data-contact-mail data-user="raymlg2005" data-domain="gmail.com" data-cursor-hover>
      Click to reveal email
    </a>
    
    <div class="contact__links">
      {socialLinks.map((link) => (
        <a href={link.href} target="_blank" rel="noopener noreferrer" class="contact__link" data-cursor-hover>
          <span>{link.label}</span>
          <span class="contact__arrow">↗</span>
        </a>
      ))}
    </div>
  </div>
</SectionLayout>

<script>
  // Anti-spambot email obfuscation
  const mailBtn = document.querySelector('[data-contact-mail]');
  if (mailBtn) {
    // Only construct the email when hovered or interacted with
    const revealEmail = () => {
      const user = mailBtn.getAttribute('data-user');
      const domain = mailBtn.getAttribute('data-domain');
      if (user && domain) {
        const email = `${user}@${domain}`;
        mailBtn.setAttribute('href', `mailto:${email}`);
        mailBtn.textContent = email;
        // Clean up listeners after revealing
        mailBtn.removeEventListener('mouseenter', revealEmail);
        mailBtn.removeEventListener('focus', revealEmail);
      }
    };
    
    mailBtn.addEventListener('mouseenter', revealEmail);
    mailBtn.addEventListener('focus', revealEmail);
  }
</script>

<style>
  .contact__body {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .contact__text {
    font-size: var(--text-subtitle);
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 500px;
  }

  .contact__email {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 3rem);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-accent);
    border-bottom: 2px solid var(--color-border);
    padding-bottom: 0.15em;
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .contact__email:hover {
    border-color: var(--color-accent);
  }

  .contact__links {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-sm);
  }

  .contact__link {
    display: flex;
    align-items: center;
    gap: 0.35em;
    font-family: var(--font-mono);
    font-size: var(--text-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .contact__link:hover {
    color: var(--color-accent);
  }

  .contact__arrow {
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .contact__link:hover .contact__arrow {
    transform: translate(2px, -2px);
  }

  @media (max-width: 768px) {
    .contact__links {
      flex-wrap: wrap;
    }
  }
</style>
