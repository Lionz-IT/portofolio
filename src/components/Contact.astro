---
import SectionLayout from '../layouts/SectionLayout.astro';

const socialLinks = [
  // Resume moved to navbar
];
---

<SectionLayout id="contact" className="contact" label="05 / Contact" title="Let's Work Together">
  <div class="contact__body" data-animate="fade-up">
    <p class="contact__text">
      Have a project in mind or just want to say hello? I'm always open to
      discussing new opportunities and ideas.
    </p>
    
    <a href="#" class="contact__email" data-contact-mail data-user="raymlg2005" data-domain="gmail.com" data-cursor-hover>
      Hover to reveal email
    </a>
  </div>
</SectionLayout>

<script>
  // Anti-spambot email obfuscation with dynamic touch/hover text
  const mailBtn = document.querySelector('[data-contact-mail]');
  if (mailBtn) {
    const isMobile = window.matchMedia('(max-width: 768px)').matches || ('ontouchstart' in window) || navigator.maxTouchPoints > 0;
    const defaultText = isMobile ? "Tap to reveal email" : "Hover to reveal email";
    
    mailBtn.textContent = defaultText;
    let originalText = defaultText;

    // Handle screen resize dynamically
    window.addEventListener('resize', () => {
      const mobile = window.matchMedia('(max-width: 768px)').matches || ('ontouchstart' in window) || navigator.maxTouchPoints > 0;
      originalText = mobile ? "Tap to reveal email" : "Hover to reveal email";
      
      // Update text on screen if it's currently not revealing the email
      if (!mailBtn.textContent.includes('@')) {
        mailBtn.textContent = originalText;
      }
    });

    const user = mailBtn.getAttribute('data-user');
    const domain = mailBtn.getAttribute('data-domain');
    
    if (user && domain) {
      const email = `${user}@${domain}`;
      
      const revealEmail = () => {
        mailBtn.setAttribute('href', `mailto:${email}`);
        mailBtn.textContent = email;
      };

      const hideEmail = () => {
        mailBtn.textContent = originalText;
      };
      
      mailBtn.addEventListener('mouseenter', revealEmail);
      mailBtn.addEventListener('focus', revealEmail);
      mailBtn.addEventListener('mouseleave', hideEmail);
      mailBtn.addEventListener('blur', hideEmail);
    }
  }
</script>

<style>
  .contact__body {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .contact__text {
    font-size: var(--text-subtitle);
    line-height: 1.6;
    color: var(--color-text-secondary);
    max-width: 500px;
  }

  .contact__email {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 3rem);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-accent);
    border-bottom: 2px solid var(--color-border);
    padding-bottom: 0.15em;
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .contact__email:hover {
    border-color: var(--color-accent);
  }

  .contact__links {
    display: flex;
    gap: var(--space-md);
    margin-top: var(--space-sm);
  }

  .contact__link {
    display: flex;
    align-items: center;
    gap: 0.35em;
    font-family: var(--font-mono);
    font-size: var(--text-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .contact__link:hover {
    color: var(--color-accent);
  }

  .contact__arrow {
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .contact__link:hover .contact__arrow {
    transform: translate(2px, -2px);
  }

  @media (max-width: 768px) {
    .contact__links {
      flex-direction: column;
      gap: var(--space-md);
      width: 100%;
    }
    
    .contact__link {
      padding: var(--space-xs) 0;
      width: 100%;
      border-bottom: 1px solid var(--color-border);
    }
    
    .contact__email {
      font-size: clamp(1.2rem, 5vw, 2rem);
      word-break: break-all;
    }
  }
</style>
