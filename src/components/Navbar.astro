---
const navLinks = [
  { label: 'About', href: '#about' },
  { label: 'Works', href: '#works' },
  { label: 'Stacks', href: '#stack' },
  { label: 'Experience', href: '#experience' },
  { label: 'Contact', href: '#contact' },
];
---

<header class="navbar">
  <a href="/" class="navbar__logo-wrapper" data-cursor-hover>
    <img src="/profile.png" alt="Lionz Logo" class="navbar__logo-img" width="32" height="32" />
    <span class="navbar__logo-text">LIONZ</span>
  </a>

  <button class="navbar__toggle" aria-expanded="false" aria-label="Menu" data-menu-toggle data-cursor-hover>
    <span class="navbar__toggle-line"></span>
    <span class="navbar__toggle-line"></span>
  </button>

  <nav class="navbar__nav" aria-label="Main navigation" data-nav>
    {
      navLinks.map((link) => (
        <a href={link.href} class="navbar__link" data-nav-link data-cursor-hover>
          {link.label}
        </a>
      ))
    }
    <a href="/resume.pdf" target="_blank" rel="noopener noreferrer" class="navbar__resume-btn" data-cursor-hover>
      RESUME
    </a>
  </nav>
</header>

<script>
  const toggle = document.querySelector('[data-menu-toggle]');
  const nav = document.querySelector('[data-nav]');
  const links = document.querySelectorAll('[data-nav-link]');

  if (toggle && nav) {
    toggle.addEventListener('click', () => {
      const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', (!isExpanded).toString());
      nav.classList.toggle('is-open');
    });

    links.forEach(link => {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        nav.classList.remove('is-open');
      });
    });
  }
</script>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-nav);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-sm) var(--gutter);
  }

  .navbar__logo-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    mix-blend-mode: difference;
    position: relative;
    z-index: 2;
  }

  .navbar__logo-img {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    object-fit: cover;
    filter: grayscale(100%) contrast(1.2);
  }

  .navbar__logo-text {
    font-family: var(--font-display);
    font-size: 1.25rem;
    letter-spacing: 0.08em;
    color: var(--color-accent);
  }

  .navbar__toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 28px;
    height: 14px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 12px;
    box-sizing: content-box;
    margin: -12px -12px -12px auto;
    mix-blend-mode: difference;
    position: relative;
    z-index: 2;
  }

  .navbar__toggle-line {
    width: 100%;
    height: 1.5px;
    background-color: var(--color-accent);
    transition: transform var(--duration-fast) var(--ease-out);
    transform-origin: center;
  }

  .navbar__nav {
    display: flex;
    gap: var(--space-md);
    mix-blend-mode: difference;
  }

  .navbar__link {
    font-family: var(--font-mono);
    font-size: var(--text-mono);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-secondary);
    transition: color var(--duration-fast) var(--ease-out);
    padding: 0.5rem;
    display: inline-block;
  }

  .navbar__link:hover {
    color: var(--color-accent);
  }

  .navbar__resume-btn {
    font-family: var(--font-mono);
    font-size: var(--text-mono);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-bg);
    background-color: var(--color-accent);
    padding: 0.5rem 1rem;
    border-radius: 4px;
    transition: all var(--duration-fast) var(--ease-out);
    display: inline-block;
    margin-left: var(--space-sm);
  }

  .navbar__resume-btn:hover {
    background-color: var(--color-text-secondary);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .navbar__toggle {
      display: flex;
    }

    .navbar__toggle[aria-expanded="true"] .navbar__toggle-line:first-child {
      transform: translateY(6.5px) rotate(45deg);
    }

    .navbar__toggle[aria-expanded="true"] .navbar__toggle-line:last-child {
      transform: translateY(-6.5px) rotate(-45deg);
    }

    .navbar__nav {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100vh;
      background-color: var(--color-bg);
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: var(--space-lg);
      transform: translateY(-100%);
      opacity: 0;
      visibility: hidden;
      transition: all var(--duration-normal) var(--ease-out);
      mix-blend-mode: normal; /* Disable difference for solid background */
      z-index: 1;
    }

    .navbar__nav.is-open {
      transform: translateY(0);
      opacity: 1;
      visibility: visible;
    }

    .navbar__link {
      font-size: var(--text-subtitle);
      color: var(--color-text);
      letter-spacing: 0.1em;
      padding: 1rem;
      width: 100%;
      text-align: center;
      display: block;
    }

    .navbar__resume-btn {
      margin-left: 0;
      margin-top: var(--space-sm);
      font-size: var(--text-subtitle);
      padding: 1rem 2rem;
    }
  }
</style>
