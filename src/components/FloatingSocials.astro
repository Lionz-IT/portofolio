---
const socials = [
  { 
    name: 'GitHub', 
    href: 'https://github.com/Lionz-IT',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>',
    color: '#ffffff'
  },
  { 
    name: 'LinkedIn', 
    href: 'https://www.linkedin.com/in/rafif-ahmad-yudhistira-04836331b/',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>',
    color: '#0a66c2'
  },
  { 
    name: 'Instagram', 
    href: 'https://instagram.com/ray.lionz',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>',
    color: '#E1306C'
  },
  { 
    name: 'Roblox', 
    href: 'https://www.roblox.com/users/profile?username=LionNichBoss',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2" transform="rotate(15 12 12)"/><rect width="6" height="6" x="9" y="9" rx="1" ry="1" transform="rotate(15 12 12)"/></svg>',
    color: '#ffffff'
  }
];
---

<div class="floating-socials">
  <div class="floating-socials__container">
    {socials.map((social) => (
      <a 
        href={social.href} 
        target="_blank" 
        rel="noopener noreferrer" 
        class="floating-socials__link" 
        data-cursor-hover
        aria-label={social.name}
        style={`--hover-color: ${social.color};`}
      >
        <Fragment set:html={social.icon} />
      </a>
    ))}
  </div>
</div>

<style>
  .floating-socials {
    position: fixed;
    bottom: var(--gutter);
    right: var(--gutter);
    z-index: var(--z-nav);
    mix-blend-mode: difference;
    pointer-events: none; /* Let the container be invisible to clicks */
  }

  .floating-socials__container {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    pointer-events: auto; /* Re-enable clicks for the links inside */
  }

  .floating-socials__link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
    transition: all var(--duration-normal) var(--ease-out);
    opacity: 0.7;
  }

  .floating-socials__link:hover {
    color: var(--hover-color, var(--color-accent));
    opacity: 1;
    transform: scale(1.15) translateY(-2px);
  }

  @media (max-width: 768px) {
    .floating-socials__container {
      gap: 1rem;
    }
    
    .floating-socials__link {
      opacity: 0.9; /* Slightly more visible on mobile by default */
    }
  }
</style>