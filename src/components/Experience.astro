---
import { experiences } from '../data/experience';
import SectionLayout from '../layouts/SectionLayout.astro';
---

<SectionLayout id="experience" className="experience" label="04 / Experience" title="Experience">
  <div class="timeline">
    <div class="timeline__line" aria-hidden="true"></div>
    {
      experiences.map((exp, i) => (
        <div class:list={['timeline__item', i % 2 === 0 ? 'timeline__item--left' : 'timeline__item--right']} data-animate="fade-up">
          <div class="timeline__dot" aria-hidden="true"></div>
          <div class="timeline__content">
            <span class="timeline__period">{exp.period}</span>
            <h3 class="timeline__role">{exp.role}</h3>
            <span class="timeline__company">{exp.company}</span>
            <p class="timeline__desc">{exp.description}</p>
          </div>
        </div>
      ))
    }
  </div>
</SectionLayout>

<style>
  .timeline {
    position: relative;
    padding: var(--space-md) 0;
    margin-top: var(--space-md);
  }

  /* Hover effect for siblings (Dim other items when timeline is hovered) */
  .timeline:hover .timeline__item:not(:hover) {
    opacity: 0.3;
    filter: grayscale(100%);
  }

  /* Garis Vertikal (Kiri di Mobile) */
  .timeline__line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 15px; 
    width: 2px;
    background-color: var(--color-border);
  }

  .timeline__item {
    position: relative;
    margin-bottom: var(--space-lg);
    padding-left: 45px; /* Jarak teks dari garis di mobile */
    width: 100%;
    box-sizing: border-box;
    transition: all 0.5s cubic-bezier(0.165, 0.84, 0.44, 1); /* Smooth fade for sibling hover */
  }

  .timeline__content {
    transition: transform 0.5s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  .timeline__item:last-child {
    margin-bottom: 0;
  }

  /* Titik/Node Timeline */
  .timeline__dot {
    position: absolute;
    top: 50%; /* Center vertically */
    left: 9px; /* Posisi di tengah garis (15px + 1px) - (14px/2) = 9px */
    width: 14px;
    height: 14px;
    transform: translateY(-50%);
    border-radius: 50%;
    background-color: var(--color-bg);
    border: 2px solid var(--color-accent);
    z-index: 2;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }

  /* Hover Effects on Item */
  .timeline__item:hover .timeline__dot {
    transform: translateY(-50%) scale(1.4);
    background-color: var(--color-accent);
    box-shadow: 0 0 20px rgba(245, 240, 235, 0.5); /* Glowing effect */
  }

  .timeline__item:hover .timeline__content {
    transform: translateX(10px); /* Slightly shift text right on mobile */
  }

  /* Konten Teks */
  .timeline__period {
    font-family: var(--font-mono);
    font-size: var(--text-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-bg);
    background-color: var(--color-text-secondary);
    display: inline-block;
    margin-bottom: var(--space-sm);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-weight: 500;
  }

  .timeline__role {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-accent);
    line-height: 1.1;
    margin-bottom: 0.25rem;
  }

  .timeline__company {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-subtitle);
    color: var(--color-text-secondary);
    display: block;
    margin-bottom: var(--space-sm);
  }

  .timeline__desc {
    font-size: var(--text-body);
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  /* ========================================================
     DESKTOP LAYOUT (Kanan-Kiri Alternating)
     ======================================================== */
  @media (min-width: 768px) {
    .timeline__line {
      left: 50%;
      transform: translateX(-50%);
    }

    .timeline__item {
      width: 50%;
      padding-left: 0;
      margin-bottom: 4rem; /* Jarak vertikal antar item */
    }

    /* KIRI */
    .timeline__item--left {
      margin-left: 0;
      padding-right: 4rem; /* Beri jarak ke garis tengah */
      text-align: right;
    }
    
    .timeline__item--left .timeline__dot {
      left: auto;
      right: -7px; /* Titik tepat di pinggir kanan box (-14px/2) */
    }

    .timeline__item--left:hover .timeline__content {
      transform: translateX(-15px); /* Shift left on hover for left items */
    }

    /* KANAN */
    .timeline__item--right {
      margin-left: 50%; /* Geser seluruh box ke kanan */
      padding-left: 4rem; /* Beri jarak ke garis tengah */
      text-align: left;
    }

    .timeline__item--right .timeline__dot {
      left: -7px; /* Titik tepat di pinggir kiri box (-14px/2) */
      right: auto;
    }

    .timeline__item--right:hover .timeline__content {
      transform: translateX(15px); /* Shift right on hover for right items */
    }
  }
</style>
